{
  "$defs": {
    "ConstructSpec": {
      "additionalProperties": false,
      "description": "A sub-Construct definition.\n\n``nodes`` references top-level :class:`NodeSpec` names by string;\nsub-constructs share the global node pool by reference, not by\ncontainment. Recursive ``NodeSpec`` nesting is not part of the spec\nformat.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "input": {
          "title": "Input",
          "type": "string"
        },
        "output": {
          "title": "Output",
          "type": "string"
        },
        "nodes": {
          "items": {
            "type": "string"
          },
          "title": "Nodes",
          "type": "array"
        },
        "oracle": {
          "anyOf": [
            {
              "$ref": "#/$defs/OracleSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "each": {
          "anyOf": [
            {
              "$ref": "#/$defs/EachSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "loop": {
          "anyOf": [
            {
              "$ref": "#/$defs/LoopSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "operator": {
          "anyOf": [
            {
              "$ref": "#/$defs/OperatorSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "name",
        "input",
        "output",
        "nodes"
      ],
      "title": "ConstructSpec",
      "type": "object"
    },
    "EachSpec": {
      "additionalProperties": false,
      "description": "Each (fan-out) modifier in a node or sub-construct spec.",
      "properties": {
        "over": {
          "title": "Over",
          "type": "string"
        },
        "key": {
          "title": "Key",
          "type": "string"
        }
      },
      "required": [
        "over",
        "key"
      ],
      "title": "EachSpec",
      "type": "object"
    },
    "LlmConfig": {
      "additionalProperties": false,
      "description": "Typed IR for the per-Node / per-Construct LLM configuration.\n\nFramework fields live here as typed attributes. Provider knobs go into\n``provider_kwargs``. Pydantic's ``extra='forbid'`` ensures any unknown\ntop-level key (including typos) raises ``ValidationError`` at Node\nconstruction time.",
      "properties": {
        "output_strategy": {
          "default": "structured",
          "enum": [
            "structured",
            "json_mode",
            "text"
          ],
          "title": "Output Strategy",
          "type": "string"
        },
        "max_retries": {
          "default": 1,
          "title": "Max Retries",
          "type": "integer"
        },
        "max_iterations": {
          "default": 20,
          "title": "Max Iterations",
          "type": "integer"
        },
        "token_budget": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Token Budget"
        },
        "announce_tool_budget": {
          "default": false,
          "title": "Announce Tool Budget",
          "type": "boolean"
        },
        "budget_exhausted_message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Budget Exhausted Message"
        },
        "provider_kwargs": {
          "additionalProperties": true,
          "title": "Provider Kwargs",
          "type": "object"
        }
      },
      "title": "LlmConfig",
      "type": "object"
    },
    "LoopSpec": {
      "additionalProperties": false,
      "description": "Loop modifier with parsed ``when`` condition.",
      "properties": {
        "when": {
          "title": "When",
          "type": "string"
        },
        "max_iterations": {
          "default": 10,
          "title": "Max Iterations",
          "type": "integer"
        },
        "on_exhaust": {
          "default": "error",
          "enum": [
            "error",
            "last"
          ],
          "title": "On Exhaust",
          "type": "string"
        }
      },
      "required": [
        "when"
      ],
      "title": "LoopSpec",
      "type": "object"
    },
    "NodeSpec": {
      "additionalProperties": false,
      "description": "A single node definition in a spec.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "mode": {
          "default": "scripted",
          "enum": [
            "think",
            "agent",
            "act",
            "scripted",
            "raw"
          ],
          "title": "Mode",
          "type": "string"
        },
        "inputs": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Inputs"
        },
        "outputs": {
          "title": "Outputs",
          "type": "string"
        },
        "prompt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "scripted_fn": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scripted Fn"
        },
        "context": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Context"
        },
        "llm_config": {
          "$ref": "#/$defs/LlmConfig"
        },
        "tools": {
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "$ref": "#/$defs/ToolSpec"
              }
            ]
          },
          "title": "Tools",
          "type": "array"
        },
        "oracle": {
          "anyOf": [
            {
              "$ref": "#/$defs/OracleSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "each": {
          "anyOf": [
            {
              "$ref": "#/$defs/EachSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "loop": {
          "anyOf": [
            {
              "$ref": "#/$defs/LoopSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "operator": {
          "anyOf": [
            {
              "$ref": "#/$defs/OperatorSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "name",
        "outputs"
      ],
      "title": "NodeSpec",
      "type": "object"
    },
    "OperatorSpec": {
      "additionalProperties": false,
      "description": "Operator modifier with registered condition name.",
      "properties": {
        "when": {
          "title": "When",
          "type": "string"
        }
      },
      "required": [
        "when"
      ],
      "title": "OperatorSpec",
      "type": "object"
    },
    "OracleSpec": {
      "additionalProperties": false,
      "description": "Oracle modifier in a node or sub-construct spec.",
      "properties": {
        "n": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "N"
        },
        "models": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Models"
        },
        "merge_fn": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Merge Fn"
        },
        "merge_prompt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Merge Prompt"
        },
        "merge_model": {
          "default": "reason",
          "title": "Merge Model",
          "type": "string"
        }
      },
      "title": "OracleSpec",
      "type": "object"
    },
    "PipelineRef": {
      "additionalProperties": false,
      "description": "Ordered reference list that defines the final pipeline composition.",
      "properties": {
        "nodes": {
          "items": {
            "type": "string"
          },
          "title": "Nodes",
          "type": "array"
        }
      },
      "required": [
        "nodes"
      ],
      "title": "PipelineRef",
      "type": "object"
    },
    "ToolSpec": {
      "additionalProperties": false,
      "description": "Per-tool budget and config (forward-compatible alternative to bare strings).",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "budget": {
          "default": 0,
          "title": "Budget",
          "type": "integer"
        },
        "config": {
          "additionalProperties": true,
          "title": "Config",
          "type": "object"
        }
      },
      "required": [
        "name"
      ],
      "title": "ToolSpec",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Top-level pipeline spec.",
  "properties": {
    "version": {
      "const": "1",
      "default": "1",
      "title": "Version",
      "type": "string"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "description": {
      "default": "",
      "title": "Description",
      "type": "string"
    },
    "types": {
      "additionalProperties": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Types",
      "type": "object"
    },
    "nodes": {
      "items": {
        "$ref": "#/$defs/NodeSpec"
      },
      "title": "Nodes",
      "type": "array"
    },
    "constructs": {
      "items": {
        "$ref": "#/$defs/ConstructSpec"
      },
      "title": "Constructs",
      "type": "array"
    },
    "pipeline": {
      "$ref": "#/$defs/PipelineRef"
    }
  },
  "required": [
    "name",
    "pipeline"
  ],
  "title": "Spec",
  "type": "object"
}
